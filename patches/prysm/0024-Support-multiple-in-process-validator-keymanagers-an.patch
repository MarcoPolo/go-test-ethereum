+// NewInteropKeymanagerFromIndices creates an interop keymanager for specific validator indices.
+func NewInteropKeymanagerFromIndices(_ context.Context, indices []uint64) (*Keymanager, error) {
+	k := &Keymanager{
+		accountsChangedFeed: new(event.Feed),
+		instanceSecKeys:     make(map[[fieldparams.BLSPubkeyLength]byte]bls.SecretKey),
+	}
+	if len(indices) == 0 {
+		return k, nil
+	}
+	pubKeys := make([][fieldparams.BLSPubkeyLength]byte, len(indices))
+	for i, idx := range indices {
+		secretKeys, publicKeys, err := interop.DeterministicallyGenerateKeys(idx, 1)
+		if err != nil {
+			return nil, errors.Wrapf(err, "could not generate interop key at index %d", idx)
+		}
+		publicKey := bytesutil.ToBytes48(publicKeys[0].Marshal())
+		pubKeys[i] = publicKey
+		k.instanceSecKeys[publicKey] = secretKeys[0]
+	}
+	k.instancePubKeys = pubKeys
+	lock.Lock()
+	for i := range pubKeys {
+		secretKeysCache[pubKeys[i]] = k.instanceSecKeys[pubKeys[i]]
+	}
+	lock.Unlock()
+	return k, nil
+}
